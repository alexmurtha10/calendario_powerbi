{
    "dataRoles": [
        {
            "displayName": "Category Data",
            "name": "category",
            "kind": "Grouping"
        },
        {
            "displayName": "Measure Data",
            "name": "measure",
            "kind": "Measure"
        },
        {
            "displayName": "Nome do Feriado",
            "name": "holidayName",
            "kind": "Grouping"
        },
        {
            "displayName": "Classificação do Dia",
            "name": "holidayClass",
            "kind": "Grouping"
        }
    ],
    "objects": {
        "dataPoint": {
            "properties": {
                "defaultColor": {
                    "type": { "fill": { "solid": { "color": true } } }
                },
                "showAllDataPoints": {
                    "type": { "bool": true }
                },
                "fill": {
                    "type": { "fill": { "solid": { "color": true } } }
                },
                "fillRule": {
                    "type": { "fill": {} }
                },
                "fontSize": {
                    "type": { "formatting": { "fontSize": true } }
                }
            }
        }
    },
    "dataViewMappings": [
        {
            "categorical": {
                "categories": {
                    "select": [
                        { "for": { "in": "category" } },
                        { "bind": { "to": "holidayName" } },
                        { "bind": { "to": "holidayClass" } }
                    ],
                    "dataReductionAlgorithm": { "top": {} }
                },
                "values": {
                    "select": [
                        { "bind": { "to": "measure" } }
                    ]
                }
            }
        }
    ],
    "privileges": []
}